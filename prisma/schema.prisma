generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id           String   @id @default(uuid())
  name         String
  category     String
  status       String
  serialNumber String   @unique
  inventoryId  String   @unique
  price        Float
  location     String
  user         String
  type         String?  
  brand        String?  
  model        String?  
  specs        String?  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  @@map("assets")
}

model SystemSettings {
  id              Int     @id @default(1)
  adminName       String  @default("System Admin")
  adminEmail      String  @default("admin@itasset.com")
  currency        String  @default("UAH")
  assetPrefix     String  @default("ITA-")
  emailNotif      Boolean @default(true)
  slackNotif      Boolean @default(false)
  slackWebhook    String  @default("")
  maintenanceMode Boolean @default(false)
}

model Server {
  id        String   @id @default(uuid())
  name      String
  ip        String
  type      String
  status    String
  cpu       String
  ram       String
  uptime    String
  createdAt DateTime @default(now())

  @@map("servers")
}

model Log {
  id        String   @id @default(cuid())
  time      String
  actor     String
  type      String
  source    String
  text      String
  createdAt DateTime @default(now())

  @@map("logs")
}

model Ticket {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("Відкрито")
  priority    String   @default("Середній")
  user        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("tickets")
}

model SecurityLog {
  id        String   @id @default(uuid())
  event     String
  ip        String
  device    String
  time      String
  status    String
  createdAt DateTime @default(now())

  @@map("security_logs")
}

model SecuritySettings {
  id          Int     @id @default(1)
  twoFactor   Boolean @default(false)
  ldapEnabled Boolean @default(false)
  apiKey      String  @default("")

  @@map("security_settings")
}


model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   
  role      String   @default("tech") 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model License {
  id             String    @id @default(cuid())
  name           String    
  softwareType   String    
  licenseKey     String?   
  totalSeats     Int       
  usedSeats      Int       @default(0) 
  expirationDate DateTime? 
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("licenses")
}

model Employee {
  id         String   @id @default(uuid())
  firstName  String
  lastName   String
  email      String   @unique
  position   String   
  department String   
  status     String   @default("Активний") 
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("employees") 
}